# ============================================================
# RAG Data Platform — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit your .env file.
# ============================================================

# --- Database (REQUIRED — no default, app will not start without this) ---
DATABASE_URL=postgresql://username:password@localhost:5432/RAG-Data
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_strong_random_password
POSTGRES_DB=RAG-Data

# --- API Keys (REQUIRED for full functionality) ---
OPENAI_API_KEY=your_openai_key
SEC_EDGAR_API_KEY=your_sec_edgar_key

# --- Security ---
# Comma-separated list of origins allowed to call the API.
# Example: ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
# API key required in the X-API-Key header for protected endpoints.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable (development only — insecure).
API_KEY=your_long_random_api_key_here

# --- Vector Store (Optional overrides) ---
# FAISS_INDEX_PATH=data/faiss_index
# FAISS_DIMENSION=1536

# --- Server (Optional overrides) ---
# API_HOST=0.0.0.0
# API_PORT=8000
